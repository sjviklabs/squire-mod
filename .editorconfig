# EditorConfig — consistent formatting across editors
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.java]
indent_size = 4

[*.{json,toml,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{bat,cmd}]
end_of_line = crlf

[gradlew]
end_of_line = lf

[gradle/wrapper/gradle-wrapper.properties]
end_of_line = lf
